# API Configuration
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=10000

# Warehouse System Configuration
VITE_WAREHOUSE_FEATURES_REAL_TIME=true
VITE_WAREHOUSE_FEATURES_BULK_OPS=true
VITE_WAREHOUSE_FEATURES_ANALYTICS=true
VITE_WAREHOUSE_FEATURES_NOTIFICATIONS=true
VITE_WAREHOUSE_FEATURES_EXPORT=true

# Cache Configuration
VITE_CACHE_WAREHOUSES_TTL=300000
VITE_CACHE_PRODUCTS_TTL=600000
VITE_CACHE_TRANSFERS_TTL=120000

# Pagination Configuration
VITE_DEFAULT_PAGE_SIZE=10
VITE_MAX_PAGE_SIZE=100

# File Upload Configuration
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Development Configuration
VITE_DEBUG_MODE=true
VITE_MOCK_API=false